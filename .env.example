# RomM Configuration
ROMM_URL=http://your-romm-instance:3000

# Authentication (Choose one: API Key or Username/Password)
ROMM_API_KEY=your_api_key_here
# ROMM_USERNAME=your_username
# ROMM_PASSWORD=your_password

# Monitoring Configuration (Default EmuDeck paths)
# Paths are comma-separated
MONITOR_PATHS=/home/deck/.var/app/org.libretro.RetroArch/config/retroarch/saves,/home/deck/Emulation/storage/Vita3K/ux0/user/00/savedata

# GitHub Reporting (Optional)
# For automated bug reporting, add your PAT and Repo (e.g. is33/SteamRomSync)
GITHUB_PAT=
GITHUB_REPO=
